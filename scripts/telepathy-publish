#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_telepathy_lib.sh
source "$SCRIPT_DIR/_telepathy_lib.sh"
require_db

if [[ $# -lt 1 ]]; then
  echo "Usage: telepathy-publish <event-type> [--summary text] [--payload json]" >&2
  exit 1
fi

event_type="$1"
shift
summary=""
payload="{}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --summary)
      summary="${2:-}"
      shift 2
      ;;
    --payload)
      payload="${2:-{}}"
      shift 2
      ;;
    *)
      summary="${summary:+$summary }$1"
      shift
      ;;
  esac
done

if [[ -z "$summary" ]]; then
  summary="$event_type"
fi

id="$(new_event_id)"
sqlite3 "$TELEPATHY_DB" "INSERT INTO team_events(id, project, event_type, actor, summary, payload_json)
VALUES ('$(sql_escape "$id")', '$(sql_escape "$TELEPATHY_PROJECT")', '$(sql_escape "$event_type")', '$(sql_escape "$TELEPATHY_ACTOR")', '$(sql_escape "$summary")', '$(sql_escape "$payload")');"

echo "$id"
