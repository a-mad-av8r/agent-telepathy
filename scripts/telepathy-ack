#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_telepathy_lib.sh
source "$SCRIPT_DIR/_telepathy_lib.sh"
require_db

if [[ $# -ne 2 ]]; then
  echo "Usage: telepathy-ack <agent> <event-id>" >&2
  exit 1
fi

sqlite3 "$TELEPATHY_DB" "INSERT OR IGNORE INTO event_acknowledgements(agent_name, event_id)
VALUES ('$(sql_escape "$1")', '$(sql_escape "$2")');"
echo "acknowledged $2 for $1"
